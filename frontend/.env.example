# VITE_API_BASE_URL=https://YOUR_RENDER_BACKEND_URL.onrender.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# Public frontend URL after Vercel/Namecheap setup. Leave blank locally.
VITE_SITE_URL=

