NODE_ENV=production
PORT=10000

# Local development frontend: http://localhost:5173
# Production frontend:
CORS_ORIGIN=https://portfolio-frontend-rose-nine.vercel.app
FRONTEND_URL=https://portfolio-frontend-rose-nine.vercel.app

# Neon PostgreSQL connection strings.
# DATABASE_URL can use Neon's pooled connection string.
# DIRECT_URL should use Neon's direct connection string for Prisma migrations.
DATABASE_URL=postgresql://USER:YOUR_NEON_PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://USER:YOUR_NEON_PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require

# AI provider options: local, openai-compatible.
# Use Gemini through its OpenAI-compatible endpoint.
AI_PROVIDER=openai-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_MODEL=gemini-3.5-flash

# Render-friendly aliases also supported by the backend:
AI_API_KEY=YOUR_GEMINI_API_KEY
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_MODEL=gemini-3.5-flash
