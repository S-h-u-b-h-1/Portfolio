NODE_ENV=development
PORT=8080

# Local: http://localhost:5173
# Production: https://your-vercel-domain.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Render production usually uses PORT=10000 or the PORT value Render injects.
# PORT=10000

# Neon PostgreSQL connection strings.
# DATABASE_URL can use Neon's pooled connection string.
# DIRECT_URL should use Neon's direct connection string for Prisma migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require

# AI provider options: local, openai-compatible
# If OPENAI_API_KEY is set, unmatched local questions can use the OpenAI-compatible provider.
AI_PROVIDER=openai-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Render-friendly aliases also supported by the backend:
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
