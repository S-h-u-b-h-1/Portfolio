PORT=5001
NODE_ENV=development

FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Optional database. Chat fallback still works when database logging is unavailable.
DATABASE_URL=
DIRECT_URL=

# Optional salt for hashing visitor IP addresses before storing analytics.
VISITOR_HASH_SALT=change-me-in-production

# Options: local, openai-compatible, gemini
AI_PROVIDER=openai-compatible
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=7000

# Gemini native example:
# AI_PROVIDER=gemini
# AI_API_KEY=
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# AI_MODEL=gemini-flash-latest

# Backward-compatible aliases also supported:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
